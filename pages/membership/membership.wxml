<view class="container">
  <view class="card member-hero">
    <view class="section-title">会员中心</view>
    <view class="sub-text">当前套餐：{{currentPlanName || '免费版'}}</view>
    <view wx:if="{{beanBalance > 0}}" class="sub-text">星鼎豆余额：{{beanBalance}}（每次生成报告扣 500 豆）</view>
    <view wx:if="{{entitlements.membership && entitlements.membership.expires_at}}" class="sub-text">到期时间：{{entitlements.membership.expires_at}}</view>
    <view wx:else class="sub-text">免费功能长期可用，充值星鼎豆解锁更多智能填报能力。</view>
  </view>

  <view wx:if="{{loadError}}" class="card error-card">
    <view class="section-title">加载异常</view>
    <view class="warn-box">{{loadError}}</view>
    <button class="secondary-btn" bindtap="loadData">重新加载</button>
  </view>

  <view wx:if="{{loading && !plans.length}}" class="card">
    <view class="sub-text">正在加载会员套餐...</view>
  </view>

  <view wx:if="{{membershipNotice}}" class="card expire-card {{membershipNotice.type}}">
    <view class="section-title">会员提醒</view>
    <view class="sub-text">{{membershipNotice.text}}</view>
    <button class="primary-btn renew-btn" loading="{{paying}}" disabled="{{paying}}" bindtap="renewCurrentPlan">立即续费</button>
  </view>

  <view wx:if="{{comparePlans.length}}" class="card compare-card">
    <view class="section-title">会员权益对比</view>
    <scroll-view scroll-x class="compare-scroll" enable-flex>
      <view class="compare-table">
        <view class="compare-row compare-header">
          <view class="compare-cell sticky-cell">权益项</view>
          <view wx:for="{{comparePlans}}" wx:key="plan_code" class="compare-cell plan-head-cell {{item.plan_code === currentPlanCode ? 'current-col' : ''}}">
            <view class="compare-plan-name">{{item.plan_name}}</view>
            <view class="compare-plan-price">{{item.price_text}}</view>
          </view>
        </view>
        <view class="compare-row">
          <view class="compare-cell sticky-cell">有效期</view>
          <view wx:for="{{comparePlans}}" wx:key="plan_code" class="compare-cell">{{item.duration_text}}</view>
        </view>
        <view class="compare-row">
          <view class="compare-cell sticky-cell">到账星鼎豆</view>
          <view wx:for="{{comparePlans}}" wx:key="plan_code" class="compare-cell">{{item.beanGrantText}}</view>
        </view>
        <view class="compare-row">
          <view class="compare-cell sticky-cell">报告消耗</view>
          <view wx:for="{{comparePlans}}" wx:key="plan_code" class="compare-cell">{{item.reportCostText}}</view>
        </view>
        <view wx:for="{{compareFeatures}}" wx:key="name" class="compare-row">
          <view class="compare-cell sticky-cell">{{item.name}}</view>
          <view wx:for="{{item.cells}}" wx:for-item="cell" wx:key="*this" class="compare-cell {{cell === '✓' ? 'check-cell' : ''}}">{{cell}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:for="{{plans}}" wx:key="plan_code" class="card plan-card {{item.plan_code === currentPlanCode ? 'current-plan' : ''}}">
    <view class="plan-head">
      <view>
        <view class="plan-name">{{item.plan_name}}</view>
        <view class="sub-text">{{item.description}}</view>
      </view>
      <view class="plan-price">{{item.displayPriceText}}</view>
    </view>
    <view class="sub-text">有效期：{{item.durationText}}</view>
    <view class="feature-list">
      <view wx:for="{{item.features}}" wx:key="*this" class="feature-item">{{item}}</view>
    </view>
    <button wx:if="{{item.plan_code === currentPlanCode}}" class="secondary-btn" disabled>当前套餐</button>
    <button wx:elif="{{item.canPay}}" class="primary-btn" data-index="{{index}}" loading="{{paying}}" disabled="{{paying}}" bindtap="startPay">立即充值</button>
    <button wx:else class="secondary-btn" disabled>免费使用</button>
  </view>

  <view class="card" wx:if="{{orders.length}}">
    <view class="section-title">我的订单</view>
    <view wx:for="{{orders}}" wx:key="order_id" class="status-row">
      <view>
        <view class="status-title">{{item.plan_name}} · {{item.amountText}}</view>
        <view class="sub-text">订单号：{{item.order_no}}</view>
        <view class="sub-text">支付时间：{{item.paid_at || '待确认'}}</view>
      </view>
      <view class="status-tag status-{{item.pay_status}}">{{item.statusText}}</view>
    </view>
  </view>

  <view class="card version-card">
    <view class="sub-text">界面版本：星鼎豆体系 v2（普通卡/金卡/白金卡）</view>
  </view>

  <view class="card">
    <view class="section-title">支付说明</view>
    <view class="warn-box">普通卡 ¥19.9 到账 2000 星鼎豆；金卡 ¥99 到账 12000 星鼎豆；白金卡 ¥168 到账 24000 星鼎豆。</view>
    <view class="warn-box">每次生成 AI 报告扣除 500 星鼎豆。星鼎豆充值后不支持退款，已消费不退还。</view>
    <view class="warn-box">支付成功后系统将自动开通会员并到账星鼎豆。若未及时到账，请稍后在会员中心查看订单状态。</view>
    <view class="warn-box">所有推荐、风险检测和 AI 解读仅供参考，不构成录取承诺，最终以官方招生政策和正式填报系统为准。</view>
  </view>
</view>
