<view class="container">
  <view class="card member-hero">
    <view class="section-title">会员中心</view>
    <view class="sub-text">当前套餐：{{entitlements && entitlements.plan ? entitlements.plan.plan_name : '免费版'}}</view>
    <view wx:if="{{entitlements.membership && entitlements.membership.expires_at}}" class="sub-text">到期时间：{{entitlements.membership.expires_at}}</view>
    <view wx:else class="sub-text">免费功能长期可用，升级会员解锁更多智能填报能力。</view>
  </view>

  <view wx:if="{{loadError}}" class="card error-card">
    <view class="section-title">加载异常</view>
    <view class="warn-box">{{loadError}}</view>
    <button class="secondary-btn" bindtap="loadData">重新加载</button>
  </view>

  <view wx:if="{{loading && !plans.length}}" class="card">
    <view class="sub-text">正在加载会员套餐...</view>
  </view>

  <view wx:if="{{membershipNotice}}" class="card expire-card {{membershipNotice.type}}">
    <view class="section-title">会员提醒</view>
    <view class="sub-text">{{membershipNotice.text}}</view>
    <button class="primary-btn renew-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="renewCurrentPlan">提交续费申请</button>
  </view>

  <view wx:for="{{plans}}" wx:key="plan_code" class="card plan-card {{item.plan_code === currentPlanCode ? 'current-plan' : ''}}">
    <view class="plan-head">
      <view>
        <view class="plan-name">{{item.plan_name}}</view>
        <view class="sub-text">{{item.description}}</view>
      </view>
      <view class="plan-price">{{item.priceText}}</view>
    </view>
    <view class="sub-text">有效期：{{item.durationText}}</view>
    <view class="feature-list">
      <view wx:for="{{item.features}}" wx:key="*this" class="feature-item">{{item}}</view>
    </view>
    <button wx:if="{{item.plan_code === currentPlanCode}}" class="secondary-btn" disabled>当前套餐</button>
    <button wx:elif="{{item.canApply}}" class="primary-btn" data-index="{{index}}" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOpenRequest">提交开通申请</button>
    <button wx:else class="secondary-btn" disabled>免费使用</button>
  </view>

  <view class="card" wx:if="{{openRequests.length}}">
    <view class="section-title">我的开通申请</view>
    <view wx:for="{{openRequests}}" wx:key="request_id" class="status-row">
      <view>
        <view class="status-title">{{item.plan_name}} · {{item.statusText}}</view>
        <view class="sub-text">申请时间：{{item.created_at}}</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{orders.length}}">
    <view class="section-title">我的订单</view>
    <view wx:for="{{orders}}" wx:key="order_id" class="status-row">
      <view>
        <view class="status-title">{{item.plan_name}} · {{item.amountText}}</view>
        <view class="sub-text">订单号：{{item.order_no}}</view>
        <view class="sub-text">支付时间：{{item.paid_at || '待确认'}}</view>
      </view>
      <view class="status-tag status-{{item.pay_status}}">{{item.statusText}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">开通说明</view>
    <view class="warn-box">会员为虚拟服务。请在本页提交开通申请后，按下方方式联系客服完成开通。小程序内暂不直接收款。</view>
    <view class="warn-box">{{supportContact.support_note || '提交申请后请联系客服，备注手机号和套餐名称。'}}</view>
    <view wx:if="{{supportContact.support_wechat}}" class="sub-text">客服微信：{{supportContact.support_wechat}}</view>
    <view wx:if="{{supportContact.support_phone}}" class="sub-text">客服电话：{{supportContact.support_phone}}</view>
    <view class="member-support-actions">
      <button wx:if="{{supportContact.support_wechat}}" class="secondary-btn" bindtap="copySupportWechat">复制客服微信</button>
      <button wx:if="{{supportContact.support_phone}}" class="secondary-btn" bindtap="callSupportPhone">拨打客服电话</button>
    </view>
    <view class="warn-box">所有推荐、风险检测和 AI 解读仅供参考，不构成录取承诺，最终以官方招生政策和正式填报系统为准。</view>
  </view>
</view>
