.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 38rpx rgba(22, 119, 255, 0.22);
}

.hero-card .sub-text {
  color: rgba(255, 255, 255, 0.86);
}

.hello {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.profile-btn {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin: 0;
}

.score-card {
  display: flex;
  justify-content: space-between;
}

.score-item {
  flex: 1;
  text-align: center;
}

.score-num {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #1677ff;
}

.score-label {
  display: block;
  color: #667085;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.grid-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-card {
  min-height: 150rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 12rpx 32rpx rgba(22, 119, 255, 0.08);
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #101828;
  margin-bottom: 10rpx;
}
