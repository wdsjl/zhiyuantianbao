.hero-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 38rpx rgba(22, 119, 255, 0.22);
}

.hero-card .sub-text {
  color: rgba(255, 255, 255, 0.86);
}

.hello {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.profile-btn {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin: 0;
}

.score-card {
  display: flex;
  justify-content: space-between;
}

.score-item {
  flex: 1;
  text-align: center;
}

.score-num {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #1677ff;
}

.score-label {
  display: block;
  color: #667085;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.grid-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-card {
  min-height: 150rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 12rpx 32rpx rgba(22, 119, 255, 0.08);
}

.highlight-action {
  background: linear-gradient(135deg, #eef5ff, #f6fffb);
  border: 2rpx solid #d6e8ff;
}

.flow-card {
  margin-bottom: 24rpx;
}

.flow-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.flow-percent {
  font-size: 40rpx;
  font-weight: 800;
  color: #1677ff;
}

.flow-bar {
  height: 16rpx;
  background: #eef2f7;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.flow-inner {
  height: 100%;
  background: linear-gradient(90deg, #1677ff, #36cfc9);
  border-radius: 999rpx;
}

.flow-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.flow-step:last-of-type {
  border-bottom: 0;
}

.flow-step.current {
  background: #f8fbff;
  border-radius: 16rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.flow-step.done .step-index {
  background: #12b76a;
}

.step-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #98a2b3;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.flow-step.current .step-index {
  background: #1677ff;
}

.step-body {
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #101828;
}

.step-status {
  font-size: 22rpx;
  color: #667085;
  flex-shrink: 0;
}

.flow-step.current .step-status {
  color: #1677ff;
  font-weight: 700;
}

.flow-step.done .step-status {
  color: #12b76a;
}

.flow-btn {
  margin-top: 20rpx;
}

.douyin-banner,
.pay-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.douyin-banner {
  background: linear-gradient(135deg, #fff0f6, #ffffff);
  border: 2rpx solid #ffadd2;
  margin-bottom: 24rpx;
}

.douyin-banner .pay-banner-title {
  color: #c41d7f;
}

.pay-banner {
  background: linear-gradient(135deg, #fff7e6, #ffffff);
  border: 2rpx solid #ffe7ba;
}

.pay-banner-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #b54708;
  margin-bottom: 8rpx;
}

.pay-banner-btn {
  width: 160rpx;
  flex-shrink: 0;
  margin: 0;
  font-size: 26rpx;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #101828;
  margin-bottom: 10rpx;
}
