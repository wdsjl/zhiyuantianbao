.hero-personality {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #ffffff;
}

.hero-personality .section-title,
.hero-personality .sub-text {
  color: #ffffff;
}

.progress-wrap {
  margin-top: 24rpx;
}

.progress-text {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.35);
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transition: width 0.2s ease;
}

.question-card {
  padding-bottom: 18rpx;
}

.question-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 22rpx;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.option-item {
  border-radius: 18rpx;
  padding: 18rpx 16rpx;
  background: #f7f9fc;
  color: #475467;
  text-align: center;
  font-size: 26rpx;
}

.option-item.active {
  background: #e8f2ff;
  color: #1677ff;
  font-weight: 700;
  box-shadow: inset 0 0 0 2rpx #1677ff;
}

.submit-btn {
  margin: 8rpx 0 40rpx;
}

.result-card {
  border: 2rpx solid #d6e8ff;
}

.result-main {
  font-size: 44rpx;
  font-weight: 800;
  color: #1677ff;
  margin-bottom: 14rpx;
}

.type-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.type-row:last-child {
  border-bottom: 0;
}

.type-code {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #1677ff;
  color: #ffffff;
  margin-right: 14rpx;
  font-weight: 700;
}

.type-name {
  font-weight: 700;
  color: #101828;
}

.type-score {
  color: #1677ff;
  font-weight: 700;
}

.major-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.major-item {
  padding: 18rpx;
  background: #f7f9fc;
  border-radius: 18rpx;
  color: #344054;
  text-align: center;
}

.personality-actions {
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
}
