<view class="container">
  <view class="card">
    <view class="section-title">身份选择</view>
    <view class="tag-row role-row">
      <text class="tag {{form.role === '学生' ? 'active' : ''}}" data-role="学生" bindtap="selectRole">学生</text>
      <text class="tag {{form.role === '家长' ? 'active' : ''}}" data-role="家长" bindtap="selectRole">家长</text>
    </view>
    <view class="sub-text">家长身份需绑定学生后，可辅助查看、修改和对比志愿方案。</view>
  </view>

  <view class="card">
    <view class="section-title">基础信息</view>
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{form.name}}" data-field="name" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="用于保存方案和身份绑定" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">省份 / 城市</text>
      <view class="inline-fields">
        <input class="input" placeholder="例如：浙江" value="{{form.province}}" data-field="province" bindinput="onInput" />
        <input class="input" placeholder="例如：杭州" value="{{form.city}}" data-field="city" bindinput="onInput" />
      </view>
    </view>
    <view class="form-item">
      <text class="label">学校 / 年级 / 班级</text>
      <view class="inline-fields three-fields">
        <input class="input" placeholder="学校" value="{{form.school}}" data-field="school" bindinput="onInput" />
        <input class="input" placeholder="年级" value="{{form.grade}}" data-field="grade" bindinput="onInput" />
        <input class="input" placeholder="班级" value="{{form.className}}" data-field="className" bindinput="onInput" />
      </view>
    </view>
    <view class="form-item">
      <text class="label">选科组合</text>
      <input class="input" placeholder="例如：物理+化学+生物" value="{{form.subjectCombination}}" data-field="subjectCombination" bindinput="onInput" />
    </view>
    <view class="form-item">
      <text class="label">高考分数 / 全省位次</text>
      <view class="inline-fields">
        <input class="input" type="number" placeholder="分数" value="{{form.score}}" data-field="score" bindinput="onInput" />
        <input class="input" type="number" placeholder="位次" value="{{form.rank}}" data-field="rank" bindinput="onInput" />
      </view>
    </view>
    <view class="form-item">
      <text class="label">目标批次</text>
      <input class="input" placeholder="本科批 / 专科批" value="{{form.targetBatch}}" data-field="targetBatch" bindinput="onInput" />
    </view>

    <view wx:if="{{form.role === '家长'}}" class="form-item">
      <text class="label">绑定学生手机号 / 绑定码</text>
      <input class="input" placeholder="请输入学生手机号或绑定码" value="{{form.bindCode}}" data-field="bindCode" bindinput="onInput" />
    </view>

    <button class="primary-btn" bindtap="saveProfile">保存并进入</button>
  </view>
</view>
