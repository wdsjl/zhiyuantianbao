.container { padding: 24rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 8rpx 24rpx rgba(22,119,255,.08); }
.section-title { font-size: 34rpx; font-weight: 700; margin-bottom: 12rpx; }
.sub-text { color: #667085; font-size: 26rpx; line-height: 1.6; margin-bottom: 8rpx; }
.summary-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; font-size: 26rpx; color: #1677ff; }
.input { background: #f7f9fc; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.tag { padding: 10rpx 20rpx; border-radius: 999rpx; background: #eef5ff; color: #1677ff; font-size: 24rpx; }
.tag.active { background: #1677ff; color: #fff; }
.item-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.school-name { font-size: 30rpx; font-weight: 600; }
.major-line { font-size: 28rpx; margin-bottom: 8rpx; }
.gradient { padding: 4rpx 12rpx; border-radius: 8rpx; font-size: 22rpx; color: #fff; }
.gradient-chong { background: #f04438; }
.gradient-wen { background: #1677ff; }
.gradient-bao { background: #12b76a; }
.gradient-dian { background: #98a2b3; }
.button-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.primary-btn, .secondary-btn { flex: 1; min-width: 200rpx; }
.load-more { padding: 0 24rpx 24rpx; }
