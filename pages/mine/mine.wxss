.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.user-name {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.edit-btn {
  width: 140rpx;
}

.vip-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #fff7e6, #fff);
  border: 2rpx solid #ffe7ba;
}

.vip-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #b54708;
  margin-bottom: 10rpx;
}

.vip-btn {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 26rpx;
}

.promo-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #eef5ff, #fff);
  border: 2rpx solid #91caff;
}

.promo-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1677ff;
  margin-bottom: 10rpx;
}

.promo-btn {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 26rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f2f4f7;
  color: #101828;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text:last-child {
  color: #98a2b3;
}

.version-line {
  text-align: center;
  font-size: 22rpx;
  color: #98a2b3;
  padding: 8rpx 0 24rpx;
}
