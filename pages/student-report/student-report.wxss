.hero-card {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
}

.hero-card .section-title,
.hero-card .sub-text {
  color: #fff;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 28rpx;
}

.info-row .label {
  color: #667085;
}

.mini-btn {
  margin-top: 16rpx;
  margin-right: 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  color: #475467;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f7f9fc;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.textarea {
  min-height: 160rpx;
}

.report-card {
  margin-bottom: 40rpx;
}

.report-content {
  white-space: pre-wrap;
  line-height: 1.85;
  color: #344054;
  font-size: 28rpx;
  margin: 20rpx 0;
}

.report-actions {
  display: flex;
  gap: 16rpx;
}

.report-actions button {
  flex: 1;
}
