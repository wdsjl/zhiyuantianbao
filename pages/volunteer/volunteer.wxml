<view class="container">
  <view class="card">
    <view class="section-title">智能梯度志愿</view>
    <view class="sub-text">仅按全省位次 X 划分冲稳保：冲 0.90X~0.95X、稳 0.95X~1.05X、保 1.15X~1.25X。</view>
    <view wx:if="{{profile.province}}" class="sub-text profile-batch-tip">
      当前档案：{{profile.province}} · {{profile.targetBatch || '未填批次'}} · {{profile.score || '--'}}分 / 位次{{profile.rank || '--'}}
      <text class="profile-edit-link" bindtap="goProfile">修改</text>
    </view>
    <view wx:if="{{provinceRule}}" class="sub-text province-rule-tip">
      本省规则：{{provinceRule.batch || profile.targetBatch}} · {{provinceRule.volunteer_mode}}，目标足额 {{provinceRule.total_slots || provinceRule.school_count}} 个志愿单位
    </view>
    <view class="section-title strategy-title">填报策略</view>
    <view class="tag-row strategy-row">
      <text
        wx:for="{{planStyleOptions}}"
        wx:key="value"
        class="tag {{planStyle === item.value ? 'active' : ''}}"
        data-style="{{item.value}}"
        bindtap="onPlanStyleChange"
      >{{item.label}}（{{item.desc}}）</text>
    </view>
    <view wx:if="{{strategyMeta}}" class="sub-text strategy-meta">
      位次区间：冲 {{strategyMeta.bands.chong[0]}}~{{strategyMeta.bands.chong[1]}}，
      稳 {{strategyMeta.bands.wen[0]}}~{{strategyMeta.bands.wen[1]}}，
      保 {{strategyMeta.bands.bao[0]}}~{{strategyMeta.bands.bao[1]}}
    </view>
    <view class="button-row">
      <button class="primary-btn" bindtap="generatePlan">智能生成</button>
      <button class="secondary-btn" bindtap="inspectRisk">风险排查</button>
    </view>
  </view>

  <view class="card ai-explain-section">
    <ai-generated-label />
    <view class="section-title">AI 志愿方案解读</view>
    <view class="sub-text">基于当前志愿方案、分数位次与个人报告，由大模型生成解读说明。</view>
    <button class="secondary-btn ai-explain-btn" loading="{{aiLoading}}" bindtap="explainPlan">{{aiExplain ? '重新生成 AI 解读' : 'AI 志愿解读'}}</button>
    <view wx:if="{{aiExplain}}" class="ai-explain-result">
      <ai-generated-label />
      <view class="ai-explain-text">{{aiExplain}}</view>
      <view class="ai-action-row">
        <button class="secondary-btn" bindtap="copyAiExplain">复制解读</button>
      </view>
    </view>
    <view class="warn-box">AI 解读仅供辅助理解，不能替代各省教育考试院、高校招生章程和正式填报系统。</view>
  </view>

  <view wx:if="{{personality.code}}" class="card personality-match-card">
    <view class="section-title">性格专业匹配</view>
    <view class="sub-text">测评结果：{{personality.code}} · {{personality.primaryType.name}}</view>
    <view class="tag-row personality-tags">
      <text wx:for="{{personality.majorTypes}}" wx:key="*this" class="tag active">{{item}}</text>
    </view>
    <view class="warn-box">推荐会优先提示与你性格匹配的专业方向，但最终仍需结合位次、选科和招生计划综合判断。</view>
  </view>

  <view wx:if="{{riskResult}}" class="card">
    <view class="risk-title">综合风险：<text class="{{riskClass}}">{{riskResult.level}}</text></view>
    <view class="gradient-stat">
      <text>冲 {{riskResult.chong}}</text>
      <text>稳 {{riskResult.wen}}</text>
      <text>保 {{riskResult.bao}}</text>
      <text>垫 {{riskResult.dian}}</text>
    </view>
    <view wx:for="{{riskResult.warnings}}" wx:key="*this" class="warn-box warning-item">{{item}}</view>
  </view>

  <view wx:for="{{plan}}" wx:key="id" class="card volunteer-card">
    <view class="volunteer-head">
      <view>
        <text class="gradient gradient-{{item.gradientClass}}">{{item.gradientType}}</text>
        <text class="school-name">{{item.schoolName}}</text>
      </view>
      <text class="{{item.riskLevel === '高' ? 'risk-high' : item.riskLevel === '中' ? 'risk-mid' : 'risk-low'}}">{{item.riskLevel}}风险</text>
    </view>
    <view class="sub-text">{{item.city}} · {{item.schoolType}} · {{item.duration}} · {{item.tuition}}元/年</view>
    <view class="major-line">专业：{{item.majorName}}（{{item.majorCode}}）</view>
    <view wx:if="{{item.admissionProbability}}" class="sub-text">录取概率参考：{{item.admissionProbability}}</view>
    <view wx:if="{{item.personalityMatched}}" class="match-badge">与性格测评推荐专业大类匹配：{{item.majorType}}</view>
    <view class="adjust-row">
      <view>
        <view class="label adjust-label">是否服从专业调剂</view>
        <view class="sub-text">{{item.isAdjustable ? '降低退档风险，但可能录取到非首选专业' : '若专业未录取，可能导致退档'}}</view>
      </view>
      <switch checked="{{item.isAdjustable}}" data-index="{{index}}" bindchange="toggleAdjust" />
    </view>
    <view class="warn-box">{{item.riskReason}}</view>
    <button class="danger-btn remove-btn" data-index="{{index}}" bindtap="removePlanItem">移除该志愿</button>
  </view>

  <view wx:if="{{pdfFileName}}" class="sub-text" style="padding:0 24rpx 12rpx">PDF 文件名：{{pdfFileName}}</view>
  <view wx:if="{{plan.length}}" class="bottom-actions">
    <button class="secondary-btn" bindtap="goCompare">方案对比</button>
    <button class="secondary-btn" bindtap="generatePlanPdf">① 生成PDF</button>
    <button class="secondary-btn" bindtap="sendPlanPdfToWeChat" disabled="{{!pdfReady}}">② 发送微信</button>
    <button class="primary-btn" bindtap="saveDraft">保存草稿</button>
  </view>
</view>
