.hint-banner {
  margin-bottom: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #fff7e6;
  color: #b54708;
  font-size: 24rpx;
}

.tab-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: #eef2f8;
  color: #667085;
  font-size: 26rpx;
  font-weight: 600;
}

.tab-item.active {
  background: #1677ff;
  color: #ffffff;
}

.search-card {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-card .input {
  flex: 1;
}

.filter-btn {
  width: 150rpx;
}

.filter-group {
  margin-bottom: 26rpx;
}

.result-summary {
  color: #667085;
  margin: 18rpx 4rpx;
}

.load-more {
  text-align: center;
  color: #98a2b3;
  font-size: 24rpx;
  padding: 24rpx 0 40rpx;
}

.school-card {
  position: relative;
}

.school-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.school-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 8rpx;
}

.rank-box {
  text-align: right;
}

.rank {
  display: block;
  color: #1677ff;
  font-size: 24rpx;
  white-space: nowrap;
}

.rank-score {
  display: block;
  color: #667085;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.small-tags {
  margin-bottom: 16rpx;
}

.majors {
  color: #344054;
  line-height: 1.6;
  margin-bottom: 18rpx;
}

.add-btn {
  width: 280rpx;
  margin-left: auto;
}

.type-row {
  margin-top: 16rpx;
}

.query-form {
  margin-top: 20rpx;
}

.block-input {
  width: 100%;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.query-result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f0f7ff;
}

.result-line {
  color: #667085;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.result-highlight {
  color: #1677ff;
  font-size: 32rpx;
  font-weight: 700;
}

.admission-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.admission-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #101828;
  margin-bottom: 8rpx;
}

.score-line {
  color: #1677ff;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.announcement-card {
  border-left: 8rpx solid #1677ff;
}

.announcement-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.announcement-type {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 600;
}

.parsed-tag {
  color: #12b76a;
  font-size: 22rpx;
}

.announcement-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #101828;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.loading-tip,
.empty-card .sub-text {
  padding: 12rpx 4rpx;
}
