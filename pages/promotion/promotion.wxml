<view class="container">
  <view class="card hero-card">
    <view class="section-title">达人推广中心</view>
    <view class="sub-text">领取专属海报，用户扫码后将绑定为您的推广用户。用户充值会员后，您与平台均可查看订单并参与分账。</view>
  </view>

  <view class="card" wx:if="{{loading}}">
    <view class="sub-text">正在加载推广信息...</view>
  </view>

  <view wx:else>
    <view class="card stats-card">
      <view class="section-title">数据看板</view>
      <view class="filter-row">
        <view class="filter-item {{days===7?'active':''}}" data-days="7" bindtap="onDaysChange">近7天</view>
        <view class="filter-item {{days===30?'active':''}}" data-days="30" bindtap="onDaysChange">近30天</view>
        <view class="filter-item {{days===90?'active':''}}" data-days="90" bindtap="onDaysChange">近90天</view>
      </view>
      <view class="stats-row">
        <view class="stat-item"><view class="stat-num">{{rangeStats.scan_count || 0}}</view><view class="stat-label">扫码次数</view></view>
        <view class="stat-item"><view class="stat-num">{{rangeStats.bind_users || 0}}</view><view class="stat-label">绑定用户</view></view>
        <view class="stat-item"><view class="stat-num">{{rangeStats.paid_orders || 0}}</view><view class="stat-label">付费订单</view></view>
        <view class="stat-item"><view class="stat-num">{{rangeStats.conversion_rate || 0}}%</view><view class="stat-label">转化率</view></view>
      </view>
      <view class="stats-row">
        <view class="stat-item"><view class="stat-num">¥{{rangeStats.commission_amount || 0}}</view><view class="stat-label">区间佣金</view></view>
        <view class="stat-item"><view class="stat-num">¥{{wallet.available_amount || 0}}</view><view class="stat-label">可提现</view></view>
      </view>
      <button class="secondary-btn" bindtap="goWithdraw">提现中心</button>
    </view>

    <view class="card level-card">
      <view class="section-title">达人等级</view>
      <view class="level-head">
        <view class="level-badge">{{level.level_name || '新手达人'}}</view>
        <view class="sub-text">当前有效佣金：{{level.effective_commission_rate || agent.commission_rate || 0}}%（基础 {{level.base_commission_rate || agent.commission_rate || 0}}% + 等级加成 {{level.rate_bonus || 0}}%）</view>
      </view>
      <view class="level-progress">
        <view class="progress-bar"><view class="progress-fill" style="width: {{level.progress_percent || 0}}%"></view></view>
        <view class="sub-text" wx:if="{{level.next_level_name}}">再带来 {{level.orders_to_next || 0}} 笔付费订单可升至「{{level.next_level_name}}」</view>
        <view class="sub-text" wx:else>已达最高等级，继续保持推广势头！</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">我的推广码（达人ID：{{agent.agent_id || '--'}}）</view>
      <view class="invite-code">{{agent.invite_code || '--'}}</view>
      <view class="sub-text">基础佣金：{{agent.commission_rate || 0}}% · 等级：{{level.level_key || 'L1'}}</view>
    </view>

    <view class="card poster-card">
      <view class="section-title">专属推广海报</view>
      <view class="sub-text">选择模板后生成带昵称的海报，一键保存到相册。</view>
      <view class="template-row">
        <view wx:for="{{templates}}" wx:key="template_key" class="template-item {{templateKey===item.template_key?'active':''}}" data-key="{{item.template_key}}" bindtap="onTemplateChange">
          <view class="template-color" style="background: {{item.bg_color}}"></view>
          <view class="template-name">{{item.template_name}}</view>
        </view>
      </view>
      <canvas canvas-id="posterCanvas" class="poster-canvas" style="width: 600rpx; height: 900rpx;"></canvas>
      <image wx:if="{{composedPoster}}" class="poster-image" src="{{composedPoster}}" mode="widthFix" show-menu-by-longpress="{{true}}" />
      <button class="primary-btn" bindtap="composePoster">生成海报</button>
      <button class="secondary-btn" bindtap="savePoster" disabled="{{!composedPoster}}">保存海报到相册</button>
    </view>

    <view class="card">
      <view class="section-title">推广物料库</view>
      <view wx:if="{{!materials.length}}" class="sub-text">暂无素材，请联系运营上传。</view>
      <view wx:for="{{materials}}" wx:key="material_id" class="list-item">
        <view class="item-title">{{item.category}} · {{item.title}}</view>
        <view class="material-content">{{item.content}}</view>
        <button class="secondary-btn mini-btn" data-content="{{item.content}}" bindtap="copyMaterial">一键复制</button>
      </view>
    </view>

    <view class="card">
      <view class="section-title">我的推广用户</view>
      <view wx:if="{{!invitees.length}}" class="sub-text">暂无推广用户，分享海报后开始统计。</view>
      <view wx:for="{{invitees}}" wx:key="user_id" class="list-item">
        <view class="item-title">{{item.name || '未填写姓名'}}</view>
        <view class="sub-text">{{item.phone || '未留手机'}} · 付费 {{item.paid_orders || 0}} 单 · ¥{{item.paid_amount || 0}}</view>
        <view class="sub-text">绑定时间：{{item.bound_at}}</view>
      </view>
    </view>

    <view class="card" wx:if="{{faqs.length}}">
      <view class="section-title">常见问题</view>
      <view wx:for="{{faqs}}" wx:key="faq_id" class="faq-item">
        <view class="faq-question" data-id="{{item.faq_id}}" bindtap="toggleFaq">
          <text>{{item.question}}</text>
          <text class="faq-arrow">{{expandedFaqId === item.faq_id ? '−' : '+'}}</text>
        </view>
        <view class="faq-answer" wx:if="{{expandedFaqId === item.faq_id}}">{{item.answer}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">分账记录</view>
      <view wx:if="{{!commissions.length}}" class="sub-text">暂无分账记录。</view>
      <view wx:for="{{commissions}}" wx:key="commission_id" class="list-item">
        <view class="item-title">订单 {{item.order_no}} · ¥{{item.commission_amount}}</view>
        <view class="sub-text">{{item.invitee_name || '用户'}} · {{item.status === 'settled' ? '已结算' : (item.status === 'pending' ? '待平台确认' : '已取消')}}</view>
      </view>
    </view>
  </view>
</view>
