.hero-card {
  background: linear-gradient(135deg, #1677ff 0%, #3b8cff 100%);
  color: #fff;
}

.hero-card .section-title,
.hero-card .sub-text {
  color: #fff;
}

.invite-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #1677ff;
  margin: 16rpx 0;
  letter-spacing: 4rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f7fb;
  color: #7a8499;
  font-size: 24rpx;
}

.filter-item.active {
  background: #1677ff;
  color: #fff;
}

.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.stat-item {
  width: calc(50% - 8rpx);
  background: #f5f7fb;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
}

.stat-label {
  font-size: 24rpx;
  color: #7a8499;
  margin-top: 8rpx;
}

.template-row {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.template-item {
  text-align: center;
}

.template-item.active .template-name {
  color: #1677ff;
  font-weight: 600;
}

.template-color {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  margin: 0 auto 8rpx;
}

.template-name {
  font-size: 22rpx;
  color: #7a8499;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.poster-image {
  width: 100%;
  margin: 24rpx 0;
  border-radius: 16rpx;
  background: #f5f7fb;
}

.material-content {
  font-size: 26rpx;
  color: #4a5568;
  line-height: 1.6;
  margin: 12rpx 0;
  white-space: pre-wrap;
}

.mini-btn {
  margin-top: 8rpx;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1px solid #eef1f6;
}

.list-item:last-child {
  border-bottom: none;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2430;
}

.primary-btn,
.secondary-btn {
  margin-top: 16rpx;
}
