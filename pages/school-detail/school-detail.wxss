.school-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 12rpx;
}

.meta-line {
  color: #667085;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.plan-card {
  margin-top: 8rpx;
}

.plan-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #101828;
}

.plan-meta {
  color: #667085;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.score-line {
  color: #344054;
  margin-bottom: 16rpx;
}

.add-btn {
  width: 220rpx;
  margin-left: auto;
}

.announcement-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-type {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.announcement-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #101828;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
